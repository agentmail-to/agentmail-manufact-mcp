# Spike env — copy this file to .env and fill in real values
# ============================================================================

# ----- Clerk (OAuth path) -----
# Required for the OAuth path. If both are absent the server runs in
# legacy API-key-only mode (no Clerk at all, original behavior).
# Use the SAME Clerk instance the console uses for the target environment:
#   - Local dev / Manufact preview deploys: dev instance (pk_test_...)
#   - Production: prod instance (pk_live_...)
CLERK_PUBLISHABLE_KEY=pk_test_c2Vuc2libGUtY3Jhd2RhZC00NS5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ----- AgentMail backend -----
# Where to send API calls. Match this to the Clerk instance:
#   - dev Clerk → https://api.agentmail.sh   (staging backend)
#   - prod Clerk → https://api.agentmail.to  (production backend)
AGENTMAIL_API_URL=https://api.agentmail.sh

# ----- Console JWT signing key (OAuth path) -----
# The AgentMail backend trusts JWTs signed by this key with iss=agentmail-console,
# aud=agentmail-api. Same ES256 PEM as agentmail-web/apps/console/.env.local for
# the matching environment.
#
# Two formats accepted:
#   1. Raw PEM (multi-line). Works in local .env files. Quote it.
#   2. Base64-encoded PEM (single line). Use this when the hosting platform
#      env-var UI doesn't accept multi-line values (e.g. Manufact).
#      Generate with: cat key.pem | base64 | tr -d '\n'
CONSOLE_JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
MHcCAQEEIBNyUaLAPN/OucKB5sISu9GTnDmQ1B4bmDSE88qXoxn2oAoGCCqGSM49
AwEHoUQDQgAEnPWwKpEGWilydKAwe1SQ4WI4kr1zZRLg6pJX/yrQP2S6qxYwtD1Q
c7e7NLxMSmfIZedQSjXlW6Se06VI1VUgmg==
-----END EC PRIVATE KEY-----"

# ----- API key path (legacy) -----
# Optional server-wide fallback API key. Most users pass keys per-request
# via ?apiKey= or x-api-key header instead.
# AGENTMAIL_API_KEY=am_...

# ----- Public URL (deployments only) -----
# Required for deployments behind a reverse proxy that rewrites the Host
# header to an internal hostname (e.g. fly.io, where req.headers.host
# becomes mcp-cXXXX-N.fly.dev). When set, the server uses this as the
# canonical URL for self-referential OAuth metadata (WWW-Authenticate
# resource_metadata pointer + /.well-known/oauth-protected-resource body).
# Don't set locally — Express sees localhost:3000 correctly.
#   Production: https://mcp.agentmail.to
#   Preview:    https://<preview-id>.run.mcp-use.com
# MCP_PUBLIC_URL=https://mcp.agentmail.to

# ----- Server -----
PORT=3000
