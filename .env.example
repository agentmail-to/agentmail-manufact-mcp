# Spike env — copy this file to .env and fill in real values
# ============================================================================

# ----- Clerk (OAuth path) -----
# Required for the OAuth path. If both are absent the server runs in
# legacy API-key-only mode (no Clerk at all, original behavior).
# Use the SAME Clerk instance the console uses for the target environment:
#   - Local dev / Manufact preview deploys: dev instance (pk_test_...)
#   - Production: prod instance (pk_live_...)
CLERK_PUBLISHABLE_KEY=pk_test_c2Vuc2libGUtY3Jhd2RhZC00NS5jbGVyay5hY2NvdW50cy5kZXYk
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ----- AgentMail backend -----
# Where to send API calls. Match this to the Clerk instance:
#   - dev Clerk → https://api.agentmail.sh   (staging backend)
#   - prod Clerk → https://api.agentmail.to  (production backend)
AGENTMAIL_API_URL=https://api.agentmail.sh

# ----- Console JWT signing key (OAuth path) -----
# Same ES256 PEM as agentmail-web/apps/console/.env.local. The AgentMail
# backend trusts JWTs signed by this key with iss=agentmail-console,
# aud=agentmail-api. For prod deployment use the prod console JWT key.
# Multi-line PEM — keep newlines as-is.
CONSOLE_JWT_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
MHcCAQEEIBNyUaLAPN/OucKB5sISu9GTnDmQ1B4bmDSE88qXoxn2oAoGCCqGSM49
AwEHoUQDQgAEnPWwKpEGWilydKAwe1SQ4WI4kr1zZRLg6pJX/yrQP2S6qxYwtD1Q
c7e7NLxMSmfIZedQSjXlW6Se06VI1VUgmg==
-----END EC PRIVATE KEY-----"

# ----- API key path (legacy) -----
# Optional server-wide fallback API key. Most users pass keys per-request
# via ?apiKey= or x-api-key header instead.
# AGENTMAIL_API_KEY=am_...

# ----- Server -----
PORT=3000
